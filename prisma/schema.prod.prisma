// MySQL production schema. Mirror of schema.prisma but with `provider = "mysql"` and
// `@db.Text` annotations on long-text fields (markdown content, json transcripts, descriptions).
// Use on the VPS via:  npx prisma db push --schema=prisma/schema.prod.prisma
// or:  npx prisma generate --schema=prisma/schema.prod.prisma

datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model SiteSetting {
  id                   String   @id @default("singleton")
  siteName             String
  logoText             String
  heroTitle            String   @db.Text
  heroDescription      String   @db.Text
  heroBannerImage      String?
  heroBannerAlt        String?
  heroOverlayTitle           String?  @db.Text
  heroOverlaySubtitle        String?  @db.Text
  heroOverlayCtaPrimaryLabel String?
  heroOverlayCtaPrimaryHref  String?
  heroOverlayCtaSecondaryLabel String?
  heroOverlayCtaSecondaryHref  String?
  primaryCtaLabel      String
  primaryCtaHref       String
  projectsTitle        String
  projectsTitleAccent  String?
  projectsDescription  String   @db.Text
  sectorsTitle         String
  sectorsDescription   String   @db.Text
  featuresDescription  String   @db.Text
  finalCtaTitle        String   @db.Text
  finalCtaDescription  String   @db.Text
  ctaNote              String?  @db.Text
  contactEmail         String?
  contactPhone         String?
  seoTitle             String?
  seoDescription       String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  category       String
  sector         String
  status         String   @default("Yayında")
  shortDesc      String   @db.Text
  content        String   @db.LongText
  coverImage     String?
  accent         String   @default("#0f8ea8")
  year           Int?
  liveUrl        String?
  isFeatured     Boolean  @default(false)
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isFeatured])
  @@index([isPublished])
  @@index([sortOrder])
}

model Feature {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  icon           String
  category       String   @default("Genel")
  visualType     String   @default("icon")
  visualImage    String?
  visualAccent   String?  @default("#B87333")
  shortDesc      String   @db.Text
  content        String   @db.LongText
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SolutionCard {
  id           String   @id @default(cuid())
  slug         String   @unique
  question     String   @db.Text
  answer       String   @db.Text
  proof        String?  @db.Text
  brands       String?  @db.Text
  icon         String?
  visualImage  String?
  visualAccent String?  @default("#B87333")
  isPublished  Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}

model Sector {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  shortDesc      String   @db.Text
  content        String   @db.LongText
  accent         String   @default("#13a88b")
  isFeatured     Boolean  @default(false)
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Post {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  excerpt        String   @db.Text
  content        String   @db.LongText
  coverImage     String?
  tag            String   @default("Rehber")
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Testimonial {
  id           String   @id @default(cuid())
  quote        String   @db.Text
  authorName   String
  authorRole   String?
  authorMeta   String?
  rating       Int      @default(5)
  metric1Label String?
  metric1Value String?
  metric2Label String?
  metric2Value String?
  metric3Label String?
  metric3Value String?
  videoUrl     String?
  isFeatured   Boolean  @default(false)
  isPublished  Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isFeatured])
  @@index([isPublished])
  @@index([sortOrder])
}

model OfferRequest {
  id          String   @id @default(cuid())
  fullName    String
  company     String
  email       String?
  phone       String?
  sector      String
  networkSize String?
  modules     String?  @db.Text
  selectedServices String?  @db.Text
  message     String   @db.Text
  status      String   @default("Yeni")
  internalNote String? @db.Text
  isRead      Boolean  @default(false)
  source      String   @default("form")
  chatTranscript String? @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HomeSectionItem {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String   @db.Text
  icon        String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isPublished])
  @@index([sortOrder])
}

model SeoArticleSection {
  id              String   @id @default(cuid())
  placement       String
  eyebrow         String?
  title           String   @db.Text
  intro           String   @db.Text
  tableOfContents String   @db.Text
  content         String   @db.LongText
  ctaTitle        String?  @db.Text
  ctaDescription  String?  @db.Text
  ctaLabel        String?
  ctaHref         String?
  isPublished     Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([placement])
  @@index([isPublished])
  @@index([sortOrder])
}

model Package {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String   @db.Text
  description String   @db.Text
  audience    String?  @db.Text
  priceLabel  String?
  price        String?
  pricePeriod  String?
  priceNote    String?  @db.Text
  ctaLabel    String?
  ctaHref     String?
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  features    PackageFeature[]

  @@index([isPublished])
  @@index([sortOrder])
}

model PackageFeature {
  id        String   @id @default(cuid())
  packageId String
  label     String   @db.Text
  value     String   @db.Text
  group     String   @default("Kapsam")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([sortOrder])
}

model FaqCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       FaqItem[]

  @@index([isPublished])
  @@index([sortOrder])
}

model FaqItem {
  id          String      @id @default(cuid())
  categoryId  String
  question    String      @db.Text
  answer      String      @db.Text
  isFeatured  Boolean     @default(false)
  isPublished Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isPublished])
  @@index([sortOrder])
}

model OfferServiceOption {
  id          String   @id @default(cuid())
  label       String
  value       String   @unique
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}
