// MySQL production schema. Mirror of schema.prisma but with `provider = "mysql"` and
// `@db.Text` annotations on long-text fields (markdown content, json transcripts, descriptions).
// Use on the VPS via:  npx prisma db push --schema=prisma/schema.prod.prisma
// or:  npx prisma generate --schema=prisma/schema.prod.prisma

datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model SiteSetting {
  id                   String   @id @default("singleton")
  siteName             String
  logoText             String
  heroTitle            String   @db.Text
  heroDescription      String   @db.Text
  heroBannerImage      String?
  heroBannerAlt        String?
  heroOverlayTitle           String?  @db.Text
  heroOverlaySubtitle        String?  @db.Text
  heroOverlayCtaPrimaryLabel String?
  heroOverlayCtaPrimaryHref  String?
  heroOverlayCtaSecondaryLabel String?
  heroOverlayCtaSecondaryHref  String?
  primaryCtaLabel      String
  primaryCtaHref       String
  projectsTitle        String
  projectsTitleAccent  String?
  projectsDescription  String   @db.Text
  sectorsTitle         String
  sectorsDescription   String   @db.Text
  featuresDescription  String   @db.Text
  finalCtaTitle        String   @db.Text
  finalCtaDescription  String   @db.Text
  ctaNote              String?  @db.Text
  contactEmail         String?
  contactPhone         String?
  seoTitle             String?
  seoDescription       String?  @db.Text
  // Faz 1 — Anasayfa hero alanları
  heroEyebrow          String?
  heroRotatingWords    String?  @db.Text
  heroTitleLead        String?
  heroTitleConnector   String?
  heroHighlight        String?
  heroChecklist        String?  @db.Text
  heroPrimaryCta       String?
  heroSecondaryCta     String?
  trustTags            String?  @db.Text
  integrationsTitle    String?  @db.Text
  integrationsDesc     String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Feature {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  icon           String
  category       String   @default("Genel")
  visualType     String   @default("icon")
  visualImage    String?
  visualAccent   String?  @default("#B87333")
  shortDesc      String   @db.Text
  content        String   @db.LongText
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SolutionCard {
  id           String   @id @default(cuid())
  slug         String   @unique
  question     String   @db.Text
  answer       String   @db.Text
  proof        String?  @db.Text
  brands       String?  @db.Text
  icon         String?
  visualImage  String?
  visualAccent String?  @default("#B87333")
  isPublished  Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}

model Sector {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  shortDesc      String   @db.Text
  content        String   @db.LongText
  accent         String   @default("#13a88b")
  isFeatured     Boolean  @default(false)
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Post {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  excerpt        String   @db.Text
  content        String   @db.LongText
  coverImage     String?
  tag            String   @default("Rehber")
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Testimonial {
  id           String   @id @default(cuid())
  quote        String   @db.Text
  authorName   String
  authorRole   String?
  authorMeta   String?
  rating       Int      @default(5)
  metric1Label String?
  metric1Value String?
  metric2Label String?
  metric2Value String?
  metric3Label String?
  metric3Value String?
  videoUrl     String?
  isFeatured   Boolean  @default(false)
  isPublished  Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isFeatured])
  @@index([isPublished])
  @@index([sortOrder])
}

model OfferRequest {
  id          String   @id @default(cuid())
  fullName    String
  company     String
  email       String?
  phone       String?
  sector      String
  networkSize String?
  modules     String?  @db.Text
  selectedServices String?  @db.Text
  message     String   @db.Text
  status      String   @default("Yeni")
  internalNote String? @db.Text
  isRead      Boolean  @default(false)
  source      String   @default("form")
  chatTranscript String? @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HomeSectionItem {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String   @db.Text
  icon        String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isPublished])
  @@index([sortOrder])
}

model SeoArticleSection {
  id              String   @id @default(cuid())
  placement       String
  eyebrow         String?
  title           String   @db.Text
  intro           String   @db.Text
  tableOfContents String   @db.Text
  content         String   @db.LongText
  ctaTitle        String?  @db.Text
  ctaDescription  String?  @db.Text
  ctaLabel        String?
  ctaHref         String?
  isPublished     Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([placement])
  @@index([isPublished])
  @@index([sortOrder])
}

model Package {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String   @db.Text
  description String   @db.Text
  audience    String?  @db.Text
  priceLabel  String?
  price        String?
  pricePeriod  String?
  priceNote    String?  @db.Text
  ctaLabel    String?
  ctaHref     String?
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  features    PackageFeature[]

  @@index([isPublished])
  @@index([sortOrder])
}

model PackageFeature {
  id        String   @id @default(cuid())
  packageId String
  label     String   @db.Text
  value     String   @db.Text
  group     String   @default("Kapsam")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([sortOrder])
}

model FaqCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       FaqItem[]

  @@index([isPublished])
  @@index([sortOrder])
}

model FaqItem {
  id          String      @id @default(cuid())
  categoryId  String
  question    String      @db.Text
  answer      String      @db.Text
  isFeatured  Boolean     @default(false)
  isPublished Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isPublished])
  @@index([sortOrder])
}

model OfferServiceOption {
  id          String   @id @default(cuid())
  label       String
  value       String   @unique
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}

// =====================================================================
// FAZ 1 — Anasayfa hardcoded içerik
// =====================================================================

model BusinessModelCard {
  id          String   @id @default(cuid())
  slug        String   @unique
  badge       String
  title       String   @db.Text
  description String   @db.Text
  bullets     String   @db.Text
  href        String
  color       String   @default("blue")
  image       String?
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}

model HomeStat {
  id          String   @id @default(cuid())
  value       String
  label       String
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}

model PlatformShowcaseCard {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  title       String   @db.Text
  description String   @db.Text
  image       String
  bullets     String   @db.Text
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}

model IntegrationGroup {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?       @db.Text
  icon        String?
  isPublished Boolean       @default(true)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       Integration[]

  @@index([isPublished])
  @@index([sortOrder])
}

model Integration {
  id          String           @id @default(cuid())
  groupId     String
  group       IntegrationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  description String?          @db.Text
  logo        String?
  isPublished Boolean          @default(true)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([groupId])
  @@index([isPublished])
  @@index([sortOrder])
}

// =====================================================================
// FAZ 2 — /b2b /b2c /c2c sayfa içerikleri
// =====================================================================

model BusinessModelPage {
  id               String                   @id @default(cuid())
  slug             String                   @unique
  badge            String
  title            String                   @db.Text
  highlight        String                   @db.Text
  description      String                   @db.Text
  primaryCtaLabel  String
  primaryCtaHref   String
  audience         String                   @db.Text
  integrationsCopy String                   @db.Text
  ctaTitle         String                   @db.Text
  ctaDescription   String                   @db.Text
  isPublished      Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  highlights       BusinessModelHighlight[]
  useCases         BusinessModelUseCase[]
  metrics          BusinessModelMetric[]

  @@index([isPublished])
}

model BusinessModelHighlight {
  id          String            @id @default(cuid())
  pageId      String
  page        BusinessModelPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  icon        String
  title       String            @db.Text
  description String            @db.Text
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([pageId])
  @@index([sortOrder])
}

model BusinessModelUseCase {
  id          String            @id @default(cuid())
  pageId      String
  page        BusinessModelPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  industry    String            @db.Text
  scenario    String            @db.Text
  outcome     String            @db.Text
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([pageId])
  @@index([sortOrder])
}

model BusinessModelMetric {
  id        String            @id @default(cuid())
  pageId    String
  page      BusinessModelPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  value     String
  label     String
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([pageId])
  @@index([sortOrder])
}

// =====================================================================
// FAZ 3 — Statik sayfalar + Footer
// =====================================================================

model StaticPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  heroEyebrow     String?
  heroTitle       String   @db.Text
  heroHighlight   String?  @db.Text
  heroDescription String   @db.Text
  heroCtaLabel    String?
  heroCtaHref     String?
  heroCtaSecondaryLabel String?
  heroCtaSecondaryHref  String?
  bodyTitle       String?  @db.Text
  bodyContent     String?  @db.LongText
  proofTitle      String?
  proofItems      String?  @db.Text
  visualImage     String?
  stats           String?  @db.Text
  ctaEyebrow      String?
  ctaTitle        String?  @db.Text
  ctaDescription  String?  @db.Text
  ctaLabel        String?
  ctaHref         String?
  seoTitle        String?
  seoDescription  String?  @db.Text
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isPublished])
}

model JobRole {
  id          String   @id @default(cuid())
  title       String
  icon        String?
  description String   @db.Text
  department  String?
  location    String?
  type        String?
  applyUrl    String?
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}

model FooterLink {
  id          String   @id @default(cuid())
  groupSlug   String
  groupLabel  String
  label       String
  href        String
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupSlug])
  @@index([isPublished])
  @@index([sortOrder])
}
